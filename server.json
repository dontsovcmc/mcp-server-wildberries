{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dontsovcmc/wildberries",
  "description": "MCP server for Wildberries Seller API — products, orders, supplies, analytics, advertising",
  "repository": {
    "url": "https://github.com/dontsovcmc/mcp-server-wildberries",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-server-wildberries",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "environmentVariables": [
        {
          "name": "WB_TOKEN",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
